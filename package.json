{
  "name": "@codog/vue3-infinite-loading",
  "version": "0.0.11",
  "description": "An infinite scroll plugin for Vue.js",
  "main": "./lib/index.umd.js",
  "type": "module",
  "module": "./lib/index.mjs",
  "files": [
    "lib",
    "src"
  ],
  "author": {
    "name": "Allen",
    "email": "allenforuse@gmail.com"
  },
  "scripts": {
    "serve": "vite --force --host",
    "build:lib": "rollup -c",
    "docs:dev": "npm run build:lib && vitepress dev docs",
    "docs:build": "npm run build:lib && vitepress build docs",
    "docs:deploy": "bash ./scripts/deploy_docs.sh",
    "lint": "eslint . --ext .js,.vue",
    "lint:fix": "eslint . --ext .js,.vue --fix",
    "test": "BABEL_ENV=test karma start scripts/karma.conf.js",
    "precommit": "npm run lint",
    "commitmsg": "commitlint -E GIT_PARAMS",
    "release": "bash ./scripts/release.sh",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "vue",
    "vue3",
    "vue components",
    "infinite loading",
    "infinite scroll",
    "vue infinite"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justforuse/vue3-infinite-loading.git"
  },
  "bugs": {
    "url": "https://github.com/justforuse/vue3-infinite-loading/issues"
  },
  "homepage": "https://github.com/justforuse/vue3-infinite-loading",
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitepress-demo-preview/component": "^2.3.2",
    "@vitepress-demo-preview/plugin": "^1.2.3",
    "@vuepress/plugin-google-analytics": "^1.0.0-alpha.16",
    "autoprefixer": "^9.1.5",
    "axios": "^1.13.1",
    "chai": "^3.5.0",
    "element-plus": "^2.8.5",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "focus-visible": "^4.1.5",
    "husky": "^0.14.3",
    "rollup": "^4.24.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-vue": "^6.0.0",
    "sass": "^1.80.1",
    "sass-loader": "^16.0.1",
    "sinon": "^2.4.1",
    "sinon-chai": "^2.13.0",
    "tiny-emitter": "^2.1.0",
    "vite": "^5.4.9",
    "vitepress": "^1.4.1",
    "vue": "^3.2.0",
    "vue-router": "^4.4.5"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "license": "MIT",
  "browserslist": [
    "> 1%",
    "last 1 versions",
    "last 4 Android versions",
    "last 3 iOS versions"
  ],
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "scope-enum": [
        2,
        "always",
        [
          "core",
          "config",
          "spinner",
          "deps"
        ]
      ]
    }
  },
  "pnpm": {
    "patchedDependencies": {
      "vitepress": "patches/vitepress.patch"
    }
  },
  "packageManager": "pnpm@10.20.0"
}
